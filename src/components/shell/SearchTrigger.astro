---
// Header search trigger. Opens the docs search palette (SearchPalette.astro)
// which lives in BaseLayout. The trigger button + ⌘K / Ctrl+K shortcut both
// dispatch the `maester:open-search` event the palette listens for.
//
// Per gspec/features/docs-search.md §4 P0:
//   - search trigger present in the site header
//   - keyboard-accessible with visible focus indicator
//   - descriptive accessible name
//   - activating opens the palette and moves focus to the input
---

<button
  type="button"
  class="search-trigger"
  aria-label="Search documentation"
  data-search-trigger
>
  <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" fill="none"></circle>
    <path
      d="m20 20-3.5-3.5"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      fill="none"></path>
  </svg>
  <span class="search-trigger-label">Search</span>
  <kbd class="search-trigger-kbd"><span class="kbd-mac">⌘</span><span class="kbd-pc">Ctrl</span>K</kbd>
</button>

<script>
  // Show the correct modifier hint based on platform. Done client-side
  // because the server-rendered HTML is the same for everyone.
  const isMac = typeof navigator !== 'undefined' && /Mac|iPhone|iPad/i.test(navigator.platform);
  document.documentElement.classList.toggle('is-mac', isMac);

  // Wire the trigger button to open the search palette.
  document.querySelectorAll<HTMLButtonElement>('[data-search-trigger]').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('maester:open-search'));
    });
  });

  // Global ⌘K / Ctrl+K shortcut. Per gspec/features/docs-search.md §4 P0:
  // does not interfere with the browser's built-in shortcuts (we only
  // intercept the K key when modified by exactly Cmd-on-Mac or Ctrl-elsewhere
  // and let the browser handle anything else).
  document.addEventListener('keydown', (event) => {
    const k = event.key === 'k' || event.key === 'K';
    if (!k) return;
    const mod = isMac ? event.metaKey && !event.ctrlKey : event.ctrlKey && !event.metaKey;
    if (!mod) return;
    if (event.shiftKey || event.altKey) return;
    event.preventDefault();
    window.dispatchEvent(new CustomEvent('maester:open-search'));
  });
</script>

<style>
  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--elevated);
    border: 1px solid var(--border);
    color: var(--fg-muted);
    padding: 0.4375rem 0.625rem 0.4375rem 0.5rem;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    cursor: pointer;
    min-height: 40px;
    transition:
      color 120ms ease,
      background 120ms ease,
      border-color 120ms ease;
  }

  .search-trigger:hover {
    color: var(--fg);
    border-color: var(--border-strong);
  }

  .search-trigger-label {
    margin-right: 1.5rem;
  }

  .search-trigger-kbd {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--fg-muted);
    padding: 0.125rem 0.4375rem;
    border-radius: var(--radius-sm);
    line-height: 1;
  }

  /* Mac users see ⌘; everyone else sees Ctrl. Toggled by the platform script. */
  .kbd-pc {
    display: inline;
  }
  .kbd-mac {
    display: none;
  }
  :global(html.is-mac) .kbd-pc {
    display: none;
  }
  :global(html.is-mac) .kbd-mac {
    display: inline;
  }

  @media (max-width: 768px) {
    .search-trigger-label,
    .search-trigger-kbd {
      display: none;
    }
    .search-trigger {
      padding: 0.5rem;
    }
  }
</style>

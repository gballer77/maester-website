---
// Mission statement. Per gspec/features/about-page.md §4 P0:
// visual emphasis (larger type, distinct styling), concise (1–3 sentences),
// visually separated from story and maintainership.
---

<section class="mission" aria-labelledby="mission-heading">
  <p class="mission-label" id="mission-heading">Mission</p>
  <p class="mission-statement">
    Make multi-repository documentation legible to the developers and AI
    agents that depend on it — without taking ownership away from the repos
    that produce it.
  </p>
</section>

<style>
  .mission {
    margin: 4rem 0;
    padding: 2.5rem 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    border-radius: var(--radius-md);
  }

  .mission-label {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 1rem;
  }

  .mission-statement {
    font-size: clamp(1.25rem, 1.5vw + 0.85rem, 1.625rem);
    line-height: 1.4;
    color: var(--fg);
    font-weight: 500;
    margin: 0;
    max-width: 44rem;
  }

  @media (max-width: 600px) {
    .mission {
      margin: 3rem 0;
      padding: 1.75rem 1.5rem;
    }
  }
</style>

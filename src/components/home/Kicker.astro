---
// Shared "kicker" tag — a small monospace label rendered above a section h2
// to mark the section's theme. The first character is accent-coloured.
//
// Per gspec/features/home-page.md §4 P1 "Each major content section is
// preceded by a monospace kicker tag for scannability."

interface Props {
  label: string;
}
const { label } = Astro.props;
---

<p class="kicker"><span aria-hidden="true">·</span> {label}</p>

<style>
  .kicker {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    color: var(--fg-muted);
    margin: 0 0 1.125rem;
  }
  .kicker > span {
    color: var(--accent);
    margin-right: 0.375rem;
  }
</style>

---
// Key benefits grid (3–6 cards). Per gspec/features/home-page.md §4 P0:
// each benefit has a short title and 1-2 sentence description; consistent
// layout pattern; scannable in under 30 seconds.

interface Benefit {
  title: string;
  description: string;
}

const benefits: Benefit[] = [
  {
    title: 'Source-owned config',
    description:
      'Each repo declares its publish surface in a single YAML file. The same review process that owns the code owns the docs surface.',
  },
  {
    title: 'One pass, many sources',
    description:
      'A single `maester sync` command pulls every source in your citadel into one place atomically, whether each source publishes its own manifest or the citadel declares an `includes` list.',
  },
  {
    title: 'Built for AI agents',
    description:
      'Aggregated docs at a stable, structured path: drop-in retrieval context for coding agents that need grounding.',
  },
  {
    title: 'No platform, no lock-in',
    description:
      'Plain YAML, plain git. No vendor service to subscribe to. Your sources stay where they are.',
  },
  {
    title: 'Partial clones, sparse checkouts',
    description:
      'Sync pulls only the paths the source declares — via its `maester.yaml` or the citadel-side `includes` list. No full-repo clones to land a README.',
  },
  {
    title: 'Open by default',
    description:
      'MIT-licensed CLI maintained alongside this site. Roadmap and release notes live in the open.',
  },
];
---

<section class="benefits" aria-labelledby="benefits-heading">
  <div class="benefits-header">
    <h2 id="benefits-heading">Why teams reach for it</h2>
    <p class="benefits-intro">
      Designed for multi-repo engineering organisations that want a single
      reading view of their docs without re-platforming what already works.
    </p>
  </div>

  <ul class="benefits-grid">
    {
      benefits.map((b) => (
        <li class="benefit-card">
          <h3>{b.title}</h3>
          <p>{b.description}</p>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .benefits {
    padding: 4rem 0;
    border-top: 1px solid var(--border);
  }

  .benefits-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .benefits-header h2 {
    margin-top: 0;
  }

  .benefits-intro {
    color: var(--fg-muted);
    max-width: 42rem;
    margin: 0.5rem auto 0;
    line-height: 1.6;
  }

  .benefits-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .benefit-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    transition: border-color 120ms ease;
  }

  .benefit-card:hover {
    border-color: var(--border-strong);
  }

  .benefit-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.0625rem;
    color: var(--fg);
  }

  .benefit-card p {
    margin: 0;
    color: var(--fg-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  /* Render inline-code style for `maester sync` etc. inside benefit text */
  .benefit-card :global(code),
  .benefit-card p :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--elevated);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    color: var(--fg);
  }

  @media (max-width: 900px) {
    .benefits-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .benefits-grid {
      grid-template-columns: 1fr;
    }
    .benefits {
      padding: 2.5rem 0;
    }
  }
</style>

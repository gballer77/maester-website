---
// Pagefind-backed docs search palette. Lives inside BaseLayout so the
// `<dialog>` is available on every page. Lazy-loads pagefind.js on first
// open. Supports arrow-key result navigation, enter to open, escape to
// close. Mobile: full-screen-ish layout.
//
// Per gspec/features/docs-search.md §4:
//   - P0: index covers every docs page (via pagefind.yml glob)
//   - P0: keyboard shortcut (⌘K / Ctrl+K) — handler also in BaseLayout
//   - P0: palette accepts queries and shows ranked results
//   - P0: each result shows title, matched heading (sub_result), snippet
//   - P0: full keyboard navigation
//   - P0: responsive
//   - P1: empty-state with helpful message
//   - P2: performance — debounced queries; Pagefind chunks the index

import { site } from '../../config/site';

const basePath = site.basePath.replace(/\/+$/, '');
// Pagefind ships its loader at <basePath>/pagefind/pagefind.js. The dynamic
// import below uses the URL at runtime; Vite does not statically analyse it.
const pagefindUrl = `${basePath}/pagefind/pagefind.js`;
---

<dialog class="search-palette" id="search-palette" aria-label="Search documentation">
  <div class="search-palette-inner">
    <form class="search-palette-form" role="search" onsubmit="return false;">
      <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" fill="none"></circle>
        <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"></path>
      </svg>
      <input
        type="search"
        id="search-palette-input"
        class="search-palette-input"
        placeholder="Search the documentation…"
        autocomplete="off"
        spellcheck="false"
        aria-controls="search-palette-results"
        aria-activedescendant=""
      />
      <button
        type="button"
        class="search-palette-close"
        aria-label="Close search"
        data-search-close
      >
        Esc
      </button>
    </form>

    <ul
      id="search-palette-results"
      class="search-palette-results"
      role="listbox"
      aria-label="Search results"
    >
    </ul>

    <p class="search-palette-empty" id="search-palette-empty" hidden>
      No results for <q class="search-palette-empty-query"></q>. Try a different term
      or check spelling.
    </p>

    <p class="search-palette-status" id="search-palette-status" hidden>
      Loading search index…
    </p>
  </div>
</dialog>

<script define:vars={{ pagefindUrl }}>
  const dialog = document.getElementById('search-palette');
  const input = document.getElementById('search-palette-input');
  const results = document.getElementById('search-palette-results');
  const empty = document.getElementById('search-palette-empty');
  const status = document.getElementById('search-palette-status');
  const closeBtn = document.querySelector('[data-search-close]');

  if (dialog && input && results && empty && status) {
    let pagefind = null;
    let pagefindError = false;
    let activeIndex = -1;
    let currentResults = [];

    async function ensurePagefind() {
      if (pagefind || pagefindError) return pagefind;
      try {
        status.removeAttribute('hidden');
        pagefind = await import(/* @vite-ignore */ pagefindUrl);
        if (typeof pagefind.options === 'function') {
          await pagefind.options({ excerptLength: 30 });
        }
      } catch (err) {
        pagefindError = true;
        console.error('Failed to load Pagefind:', err);
        status.textContent =
          'Search is unavailable: failed to load the index. Build the site with `npm run build` to generate it.';
      } finally {
        status.setAttribute('hidden', '');
      }
      return pagefind;
    }

    function openDialog() {
      if (typeof dialog.showModal === 'function') dialog.showModal();
      else dialog.setAttribute('open', '');
      setTimeout(() => input.focus(), 0);
      ensurePagefind();
    }

    function closeDialog() {
      if (typeof dialog.close === 'function') dialog.close();
      else dialog.removeAttribute('open');
      input.value = '';
      renderResults([]);
      empty.setAttribute('hidden', '');
      activeIndex = -1;
    }

    function setActive(index) {
      activeIndex = index;
      const items = results.querySelectorAll('[role="option"]');
      items.forEach((item, i) => {
        const active = i === index;
        item.classList.toggle('active', active);
        item.setAttribute('aria-selected', String(active));
        if (active) {
          item.scrollIntoView({ block: 'nearest' });
          input.setAttribute('aria-activedescendant', item.id);
        }
      });
      if (index === -1) input.setAttribute('aria-activedescendant', '');
    }

    function renderResults(items) {
      currentResults = items;
      results.innerHTML = '';
      items.forEach((r, i) => {
        const sub = r.sub_results && r.sub_results[0];
        const href = sub?.url || r.url;
        const heading = sub && sub.title !== r.meta?.title ? sub.title : null;
        const excerpt = sub?.excerpt || r.excerpt || '';
        const title = r.meta?.title || r.url;

        const li = document.createElement('li');
        li.setAttribute('role', 'option');
        li.id = `search-result-${i}`;
        li.setAttribute('data-href', href);
        li.innerHTML = `
          <a href="${href}">
            <div class="result-title">${escapeHtml(title)}</div>
            ${heading ? `<div class="result-heading">${escapeHtml(heading)}</div>` : ''}
            <div class="result-excerpt">${excerpt}</div>
          </a>
        `;
        results.appendChild(li);
      });
      setActive(items.length > 0 ? 0 : -1);
    }

    function escapeHtml(s) {
      const d = document.createElement('div');
      d.textContent = String(s ?? '');
      return d.innerHTML;
    }

    let searchTimer = 0;
    let currentToken = 0;
    async function runSearch(query) {
      const token = ++currentToken;
      const q = query.trim();
      if (q.length < 2) {
        renderResults([]);
        empty.setAttribute('hidden', '');
        return;
      }
      const pf = await ensurePagefind();
      if (!pf) {
        renderResults([]);
        return;
      }
      const searchResult = await (pf.debouncedSearch
        ? pf.debouncedSearch(q, {}, 60)
        : pf.search(q));
      if (token !== currentToken || !searchResult) return;
      const raw = searchResult.results ?? [];
      const slice = raw.slice(0, 15);
      const data = await Promise.all(slice.map((r) => r.data()));
      if (token !== currentToken) return;
      renderResults(data);
      if (data.length === 0) {
        empty.querySelector('.search-palette-empty-query').textContent = q;
        empty.removeAttribute('hidden');
      } else {
        empty.setAttribute('hidden', '');
      }
    }

    input.addEventListener('input', (e) => {
      const value = e.target.value;
      clearTimeout(searchTimer);
      searchTimer = window.setTimeout(() => runSearch(value), 80);
    });

    input.addEventListener('keydown', (e) => {
      const items = results.querySelectorAll('[role="option"]');
      if (e.key === 'ArrowDown' && items.length > 0) {
        e.preventDefault();
        setActive((activeIndex + 1) % items.length);
      } else if (e.key === 'ArrowUp' && items.length > 0) {
        e.preventDefault();
        setActive((activeIndex - 1 + items.length) % items.length);
      } else if (e.key === 'Enter' && activeIndex >= 0) {
        e.preventDefault();
        const item = items[activeIndex];
        const href = item.getAttribute('data-href');
        if (href) {
          closeDialog();
          window.location.href = href;
        }
      } else if (e.key === 'Escape') {
        e.preventDefault();
        closeDialog();
      }
    });

    closeBtn?.addEventListener('click', closeDialog);

    // Clicking the backdrop closes the dialog.
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) closeDialog();
    });

    // Expose open/close on the dialog element for external callers
    // (SearchTrigger and the global keyboard shortcut).
    dialog._maesterOpen = openDialog;
    dialog._maesterClose = closeDialog;

    // Global open hook — header trigger and ⌘K both dispatch this event.
    window.addEventListener('maester:open-search', openDialog);
  }
</script>

<style is:global>
  .search-palette {
    border: 0;
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--fg);
    padding: 0;
    width: min(90vw, 40rem);
    max-height: 80vh;
    box-shadow: var(--shadow-md);
  }

  .search-palette::backdrop {
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(2px);
  }

  .search-palette-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    max-height: 80vh;
  }

  .search-palette-form {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    color: var(--fg-muted);
  }

  .search-palette-input {
    flex: 1;
    background: transparent;
    border: 0;
    color: var(--fg);
    font-size: 1rem;
    padding: 0.375rem 0;
    outline: none;
    min-width: 0;
  }

  .search-palette-close {
    background: var(--elevated);
    color: var(--fg-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    cursor: pointer;
  }

  .search-palette-close:hover {
    color: var(--fg);
  }

  .search-palette-results {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
    overflow-y: auto;
    flex: 1;
  }

  .search-palette-results li {
    margin: 0;
  }

  .search-palette-results a {
    display: block;
    padding: 0.625rem 1rem;
    color: var(--fg);
    text-decoration: none;
  }

  .search-palette-results li.active a,
  .search-palette-results a:hover {
    background: var(--elevated);
    text-decoration: none;
  }

  .search-palette-results .result-title {
    font-weight: 600;
    color: var(--fg);
    font-size: 0.9375rem;
  }

  .search-palette-results .result-heading {
    color: var(--accent);
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    margin-top: 0.125rem;
  }

  .search-palette-results .result-excerpt {
    color: var(--fg-muted);
    font-size: 0.875rem;
    margin-top: 0.25rem;
    line-height: 1.5;
  }

  .search-palette-results .result-excerpt mark {
    background: color-mix(in srgb, var(--accent) 25%, transparent);
    color: var(--fg);
    padding: 0 0.125rem;
    border-radius: 2px;
  }

  .search-palette-empty,
  .search-palette-status {
    padding: 1.5rem 1rem;
    color: var(--fg-muted);
    font-size: 0.9375rem;
    text-align: center;
  }

  @media (max-width: 600px) {
    .search-palette {
      width: 96vw;
      max-height: 90vh;
    }
  }
</style>

---
// Docs sidebar. Lists every entry in src/content/docs/, grouped by the
// `group` frontmatter (with a sensible default), sorted by `order` then
// `title` within a group, with active-state for the current page.
//
// Per gspec/features/documentation-section.md §4 P0:
//   - lists every docs page
//   - grouped by frontmatter hint
//   - active state visible
//   - clicking a sidebar item navigates to that page
// Per §4 P1: preserves scroll position across navigations.

import { getCollection } from 'astro:content';
import { withBase } from '../../lib/url';

interface Props {
  /** Slug of the currently-rendered docs entry (omit on the /docs landing). */
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

// Canonical group order. Anything outside this list goes to the end,
// alphabetised.
const GROUP_ORDER: readonly string[] = ['Getting Started', 'Concepts', 'Reference'];

function inferGroup(slug: string, explicit?: string): string {
  if (explicit) return explicit;
  const head = slug.split('/')[0];
  if (head === slug) return 'Reference'; // root-level entry
  // Title-case the parent directory: "getting-started" → "Getting Started"
  return head
    .split('-')
    .map((s) => s.charAt(0).toUpperCase() + s.slice(1))
    .join(' ');
}

const entries = await getCollection('docs');

const grouped = new Map<string, typeof entries>();
for (const entry of entries) {
  const group = inferGroup(entry.slug, entry.data.group);
  const list = grouped.get(group) ?? [];
  list.push(entry);
  grouped.set(group, list);
}

for (const [group, list] of grouped) {
  list.sort((a, b) => {
    if (a.data.order !== b.data.order) return a.data.order - b.data.order;
    return a.data.title.localeCompare(b.data.title);
  });
  grouped.set(group, list);
}

function groupRank(name: string): number {
  const i = GROUP_ORDER.indexOf(name);
  return i === -1 ? GROUP_ORDER.length + name.charCodeAt(0) : i;
}

const groupsInOrder = [...grouped.entries()].sort(
  ([a], [b]) => groupRank(a) - groupRank(b),
);
---

<nav class="docs-sidebar" aria-label="Documentation">
  <a href={withBase('/docs')} class={`sidebar-home ${!currentSlug ? 'active' : ''}`}>
    Documentation
  </a>

  {
    groupsInOrder.map(([group, list]) => (
      <div class="sidebar-group">
        <h3 class="sidebar-group-heading">{group}</h3>
        <ul>
          {list.map((entry) => {
            const active = currentSlug === entry.slug;
            return (
              <li>
                <a
                  href={withBase(`/docs/${entry.slug}`)}
                  aria-current={active ? 'page' : undefined}
                  class:list={[{ active }]}
                >
                  {entry.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))
  }
</nav>

<script>
  // Preserve sidebar scroll position across page navigations.
  // Per gspec/features/documentation-section.md §4 P1.
  const STORAGE_KEY = 'maester-docs-sidebar-scroll';
  const sidebar = document.querySelector<HTMLElement>('.docs-sidebar');

  if (sidebar) {
    try {
      const saved = sessionStorage.getItem(STORAGE_KEY);
      if (saved) sidebar.scrollTop = parseInt(saved, 10) || 0;
    } catch {
      /* ignore */
    }

    const persist = () => {
      try {
        sessionStorage.setItem(STORAGE_KEY, String(sidebar.scrollTop));
      } catch {
        /* ignore */
      }
    };

    sidebar.addEventListener('scroll', persist, { passive: true });
    // Also persist when the user navigates away.
    window.addEventListener('beforeunload', persist);
  }
</script>

<style>
  .docs-sidebar {
    font-size: 0.9375rem;
    padding: 1.5rem 0.5rem 2rem 0;
  }

  .sidebar-home {
    display: block;
    color: var(--fg);
    font-weight: 600;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .sidebar-home:hover {
    background: var(--elevated);
    color: var(--fg);
    text-decoration: none;
  }

  .sidebar-home.active {
    background: var(--elevated);
    color: var(--fg);
  }

  .sidebar-group {
    margin-bottom: 1.25rem;
  }

  .sidebar-group-heading {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--fg-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0 0.75rem;
    margin: 0 0 0.375rem;
  }

  .sidebar-group ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sidebar-group a {
    display: block;
    color: var(--fg-muted);
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    border-left: 2px solid transparent;
    margin-left: -2px;
    line-height: 1.4;
  }

  .sidebar-group a:hover {
    color: var(--fg);
    background: var(--elevated);
    text-decoration: none;
  }

  .sidebar-group a.active {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    border-left-color: var(--accent);
    font-weight: 500;
  }
</style>

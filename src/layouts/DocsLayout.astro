---
// Docs page layout. Wraps BaseLayout with the docs sidebar (left),
// table of contents (right), main content area, and prev/next nav.
//
// Per gspec/features/documentation-section.md §4 P0:
//   - layout includes the site shell's header and footer (via BaseLayout)
//   - sidebar navigation on the left (or below the header on mobile)
//   - main content area for the rendered MDX
//   - table of contents adjacent to main content on desktop

import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/docs/Sidebar.astro';
import TableOfContents from '../components/docs/TableOfContents.astro';
import PrevNext from '../components/docs/PrevNext.astro';

interface Props {
  title: string;
  description: string;
  /** Slug of the currently-rendered docs entry. Omit for the /docs landing. */
  currentSlug?: string;
  headings?: MarkdownHeading[];
}

const { title, description, currentSlug, headings = [] } = Astro.props;
---

<BaseLayout title={title} description={description} contained={false}>
  <div class="docs-grid">
    <aside class="docs-aside docs-aside-left">
      <Sidebar currentSlug={currentSlug} />
    </aside>

    <article class="docs-content">
      <slot />
      {currentSlug && <PrevNext currentSlug={currentSlug} />}
    </article>

    <aside class="docs-aside docs-aside-right">
      <TableOfContents headings={headings} />
    </aside>
  </div>
</BaseLayout>

<style is:global>
  .docs-grid {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr) 220px;
    gap: 2rem;
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 1.25rem;
    min-height: calc(100vh - 8rem);
  }

  .docs-aside {
    position: sticky;
    top: 4rem;
    align-self: start;
    max-height: calc(100vh - 5rem);
    overflow-y: auto;
  }

  .docs-content {
    padding: 2.5rem 0;
    max-width: 48rem;
    min-width: 0;
  }

  /* Long-form typography for MDX bodies. */
  .docs-content > h1:first-child {
    margin-top: 0;
  }

  .docs-content h1 {
    font-size: clamp(2rem, 3vw + 1rem, 2.625rem);
    margin: 0 0 0.5rem;
  }

  .docs-content p,
  .docs-content ul,
  .docs-content ol {
    line-height: 1.7;
    color: var(--fg);
  }

  .docs-content p {
    margin: 0 0 1rem;
  }

  .docs-content ul,
  .docs-content ol {
    margin: 0 0 1rem 1.5rem;
    padding: 0;
  }

  .docs-content li {
    margin: 0.25rem 0;
  }

  .docs-content blockquote {
    border-left: 3px solid var(--accent);
    margin: 1.5rem 0;
    padding: 0.5rem 1rem;
    color: var(--fg-muted);
    background: var(--surface);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .docs-content hr {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  .docs-content :not(pre) > code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--elevated);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    color: var(--fg);
    border: 1px solid var(--border);
  }

  /* Heading anchor (from rehype-autolink-headings). */
  .docs-content :is(h2, h3, h4) .heading-anchor {
    color: var(--fg-faint);
    margin-left: 0.5rem;
    font-weight: 400;
    text-decoration: none;
    opacity: 0;
    transition: opacity 120ms ease;
  }

  .docs-content :is(h2, h3, h4):hover .heading-anchor,
  .docs-content :is(h2, h3, h4) .heading-anchor:focus-visible {
    opacity: 1;
  }

  .docs-content .heading-anchor:hover {
    color: var(--accent);
    text-decoration: none;
  }

  /* Scroll the heading into view when the URL has its anchor fragment. */
  .docs-content :is(h1, h2, h3, h4, h5, h6) {
    scroll-margin-top: 5rem;
  }

  @media (max-width: 1100px) {
    .docs-grid {
      grid-template-columns: 220px minmax(0, 1fr);
    }
    .docs-aside-right {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .docs-grid {
      grid-template-columns: 1fr;
      padding: 0 1rem;
    }
    .docs-aside {
      position: static;
      max-height: none;
      border-bottom: 1px solid var(--border);
      margin-top: 1rem;
    }
    .docs-aside-left {
      order: 2;
      margin-top: 3rem;
    }
    .docs-content {
      padding: 1.5rem 0;
      order: 1;
    }
  }
</style>

<script>
  // Heading anchor click → copy direct URL to the clipboard (instead of just
  // navigating to the fragment). Matches the copy-button UX pattern.
  // Per gspec/features/documentation-section.md §4 P0: "Each heading exposes
  // an anchor affordance that copies a direct URL to that heading."
  document.querySelectorAll<HTMLAnchorElement>('a.heading-anchor').forEach((a) => {
    a.addEventListener('click', async (event) => {
      const href = a.getAttribute('href');
      if (!href || !href.startsWith('#')) return;
      event.preventDefault();
      const url = new URL(href, window.location.href).toString();
      try {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(url);
        }
      } catch {
        /* clipboard unavailable — fall back to default navigation */
      }
      // Still update the location so the URL bar reflects the anchor and the
      // page scrolls to the heading.
      history.replaceState(null, '', href);
      document.getElementById(href.slice(1))?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>
